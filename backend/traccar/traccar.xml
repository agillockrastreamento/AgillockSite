<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>

<properties>

  <!-- ── Banco de dados (produção) ── -->
  <!-- Conecta ao serviço "postgres" da rede interna Docker (docker-compose.yml) -->
  <entry key='database.driver'>org.postgresql.Driver</entry>
  <entry key='database.url'>jdbc:postgresql://postgres:5432/traccar</entry>
  <entry key='database.user'>agillock_user</entry>
  <!-- Senha injetada via variável de ambiente POSTGRES_PASSWORD no docker-compose.yml -->
  <entry key='database.password'>${POSTGRES_PASSWORD}</entry>

  <!-- ── Web Server ── -->
  <entry key='web.port'>8082</entry>
  <entry key='web.session.timeout'>0</entry>

  <!-- ── Protocolo GT06 ── -->
  <entry key='gt06.port'>5023</entry>

  <!-- ── Fuso horário ── -->
  <entry key='time.zone'>America/Sao_Paulo</entry>

  <!-- ── Filtros de posição (produção) ── -->
  <entry key='filter.enable'>true</entry>
  <entry key='filter.invalid'>true</entry>
  <entry key='filter.zero'>true</entry>
  <entry key='filter.duplicate'>true</entry>
  <entry key='filter.future'>600</entry>

  <!-- ── Retenção de histórico ── -->
  <entry key='database.positionsHistoryDays'>365</entry>

</properties>
