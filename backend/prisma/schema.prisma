generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COLABORADOR
  VENDEDOR
}

enum StatusCliente {
  ATIVO
  INATIVO
}

enum TipoCarne {
  INDIVIDUAL
  UNIFICADO
}

enum StatusBoleto {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
  REEMBOLSADO
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senhaHash String
  role      Role
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Permissões granulares para COLABORADOR (ignoradas para outros roles)
  podeExcluirCliente      Boolean @default(true)
  podeEditarCliente       Boolean @default(true)
  podeInativarCliente     Boolean @default(true)
  podeExcluirPlaca        Boolean @default(true)
  podeInativarPlaca       Boolean @default(true)
  podeExcluirDispositivo      Boolean @default(true)
  podeInativarDispositivo     Boolean @default(true)
  podeCriarDispositivo        Boolean @default(true)
  podeEditarDispositivo       Boolean @default(true)
  podeDesvincularDispositivo  Boolean @default(true)
  podeBaixaManual         Boolean @default(true)
  podeCancelarCarne       Boolean @default(true)
  podeAlterarVencimento   Boolean @default(true)

  clientesCriados      Cliente[]          @relation("ClienteCriador")
  clientesVendidos     Cliente[]          @relation("ClienteVendedor")
  carnesGerados        Carne[]            @relation("CarneGeradoPor")
  carnesVendidos       Carne[]            @relation("CarneVendedor")
  placasVendidas       Placa[]            @relation("PlacaVendedor")
  dispositivosCriados  Dispositivo[]      @relation("DispositivoCriador")
  dispositivosVendidos Dispositivo[]      @relation("DispositivoVendedor")
  comissoes            ComissaoVendedor[]
  pagamentos           PagamentoComissao[]
}

model Cliente {
  id          String        @id @default(uuid())
  nome        String
  cpfCnpj     String?
  telefone    String?
  email       String?
  notas          String?
  dataNascimento String?
  rg             String?
  profissao      String?
  estadoCivil    String?
  tipoPessoa     String  @default("PF")
  nirc           String?
  emailCobranca  String?
  origemCliente  String?
  socios         Json?
  status      StatusCliente @default(ATIVO)
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  criadoPorId String
  criadoPor   User   @relation("ClienteCriador", fields: [criadoPorId], references: [id])
  vendedorId  String?
  vendedor    User?  @relation("ClienteVendedor", fields: [vendedorId], references: [id])

  placas                 Placa[]
  dispositivos           Dispositivo[]
  dispositivosVinculados DispositivoCliente[]
  carnes                 Carne[]
}

model Placa {
  id          String   @id @default(uuid())
  placa       String
  descricao   String?
  ativo       Boolean  @default(true)
  valorPadrao Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clienteId  String
  cliente    Cliente @relation(fields: [clienteId], references: [id])
  vendedorId String?
  vendedor   User?   @relation("PlacaVendedor", fields: [vendedorId], references: [id])

  boletos           Boleto[]
  boletosUnificados BoletoPlaca[]
}

model Carne {
  id             String    @id @default(uuid())
  tipo           TipoCarne
  efiCarneId     String?   @unique
  efiCarneLink   String?
  valorTotal     Decimal   @db.Decimal(10, 2)
  numeroParcelas Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  clienteId   String
  cliente     Cliente @relation(fields: [clienteId], references: [id])
  geradoPorId String
  geradoPor   User    @relation("CarneGeradoPor", fields: [geradoPorId], references: [id])
  vendedorId  String?
  vendedor    User?   @relation("CarneVendedor", fields: [vendedorId], references: [id])

  boletos Boleto[]
}

model Boleto {
  id            String       @id @default(uuid())
  numeroParcela Int
  valor         Decimal      @db.Decimal(10, 2)
  vencimento    DateTime
  status        StatusBoleto @default(PENDENTE)
  dataPagamento DateTime?
  valorPago     Decimal?     @db.Decimal(10, 2)
  efiChargeId   String?      @unique
  linkBoleto    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  carneId String
  carne   Carne  @relation(fields: [carneId], references: [id])
  placaId String?
  placa   Placa? @relation(fields: [placaId], references: [id])
  dispositivoId String?
  dispositivo   Dispositivo? @relation(fields: [dispositivoId], references: [id])

  placasUnificadas       BoletoPlaca[]
  dispositivosUnificados BoletoDispositivo[]
  comissoes              ComissaoVendedor[]
}

model BoletoPlaca {
  valorPlaca Decimal @db.Decimal(10, 2)

  boletoId String
  boleto   Boleto @relation(fields: [boletoId], references: [id])
  placaId  String
  placa    Placa  @relation(fields: [placaId], references: [id])

  @@id([boletoId, placaId])
}

model BoletoDispositivo {
  valorDispositivo Decimal @db.Decimal(10, 2)

  boletoId      String
  boleto        Boleto      @relation(fields: [boletoId], references: [id])
  dispositivoId String
  dispositivo   Dispositivo @relation(fields: [dispositivoId], references: [id])

  @@id([boletoId, dispositivoId])
}

model Dispositivo {
  id               String   @id @default(uuid())
  nome             String
  identificador    String   @unique
  categoria        String?
  grupo            String?
  contato          String?
  ativo            Boolean  @default(true)

  // Rastreador
  modeloRastreador    String?
  telefoneRastreador  String?
  iccid               String?
  operadora           String?

  // Veículo
  placa           String?
  marca           String?
  modeloVeiculo   String?
  cor             String?
  ano             String?
  renavam         String?
  chassi          String?
  combustivel     String?
  localInstalacao String?
  instalador      String?

  // Configurações
  consumo          String?
  limiteVelocidade Float?
  senha            String?
  ignorarOdometro  Boolean  @default(false)

  // Imagem
  imagemUrl   String?

  // Billing (equivalente a Placa)
  valorPadrao Decimal? @db.Decimal(10, 2)

  clienteId   String?
  cliente     Cliente? @relation(fields: [clienteId], references: [id])
  vendedorId  String?
  vendedor    User?    @relation("DispositivoVendedor", fields: [vendedorId], references: [id])
  criadoPorId String
  criadoPor   User     @relation("DispositivoCriador", fields: [criadoPorId], references: [id])

  boletos            Boleto[]
  boletosUnificados  BoletoDispositivo[]
  clientesVinculados DispositivoCliente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DispositivoCliente {
  dispositivoId String
  clienteId     String
  dispositivo   Dispositivo @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)
  cliente       Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  @@id([dispositivoId, clienteId])
}

model ComissaoVendedor {
  id                 String    @id @default(uuid())
  valorReferencia    Decimal   @db.Decimal(10, 2)
  percentualAplicado Decimal   @db.Decimal(5, 2)
  valorComissao      Decimal   @db.Decimal(10, 2)
  pago               Boolean   @default(false)
  dataPagamento      DateTime? // snapshot quando o boleto/cliente é excluído
  createdAt          DateTime  @default(now())

  vendedorId String
  vendedor   User    @relation(fields: [vendedorId], references: [id])
  boletoId   String?
  boleto     Boleto? @relation(fields: [boletoId], references: [id])
}

model PagamentoComissao {
  id               String   @id @default(uuid())
  vendedorId       String
  vendedor         User     @relation(fields: [vendedorId], references: [id])
  mes              String   // formato YYYY-MM
  valor            Decimal  @db.Decimal(10, 2)
  pago             Boolean  @default(false)
  comprovante      String?  // caminho relativo do arquivo (ex: "uploads/comprovantes/uuid.pdf")
  comprovanteMime  String?  // MIME type do arquivo
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([vendedorId, mes])
}

model Configuracoes {
  id              String   @id @default("1")
  percentualMenor Decimal  @default(12.50) @db.Decimal(5, 2)
  percentualMaior Decimal  @default(18.00) @db.Decimal(5, 2)
  valorReferencia Decimal  @default(50.00) @db.Decimal(10, 2)
  multaPercentual Decimal  @default(5.00)  @db.Decimal(5, 2)
  jurosDiarios    Decimal  @default(0.33)  @db.Decimal(5, 2)
  updatedAt       DateTime @updatedAt
}
