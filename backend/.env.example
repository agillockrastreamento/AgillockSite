# Banco de dados
DATABASE_URL="postgresql://agillock_user:senha_aqui@localhost:5432/agillock"
POSTGRES_PASSWORD=senha_aqui

# JWT — use uma string longa e aleatória
JWT_SECRET="troque_por_uma_chave_secreta_longa"

# EFI Bank (preencher na etapa 3)
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CERT_PATH=./cert/certificado.p12
EFI_CERT_PASSWORD=
EFI_SANDBOX=true
WEBHOOK_URL=https://api.agillock.com.br/api/efi/webhook

# CORS — origens permitidas (separar por vírgula se houver mais de uma)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# Porta da API
PORT=3000

# Seed do admin — preencher com as credenciais de produção
ADMIN_EMAIL=seu_email_admin_aqui
ADMIN_SENHA=sua_senha_segura_aqui

# Traccar
TRACCAR_URL=http://traccar:8082
TRACCAR_USER=seu_email_admin_traccar
TRACCAR_PASSWORD=sua_senha_traccar
